# Pass Authorization header through to PHP on CGI/FastCGI hosting.
# Without this, shared hosts that run PHP as CGI strip the header, which
# breaks Bearer-token auth on the Magnitu API endpoints.
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTP:Authorization} .+
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
</IfModule>

<IfModule mod_setenvif.c>
    SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1
</IfModule>
