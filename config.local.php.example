<?php
/**
 * Local credentials and per-host knobs.
 *
 * Copy this file to `config.local.php` and fill in your values. `config.local.php`
 * is git-ignored so secrets never reach the repo.
 *
 * VPS layout (path satellites):
 *   - One codebase at `/var/www/seismo`
 *   - Entries + ingest in database `seismo` (mothership)
 *   - Each desk: `seismo_<slug>` scores DB + URL `https://seismo.live/<slug>/`
 *   - Register desks in Settings → Satellites, then run `bin/seismo-satellite-provision.sh <slug>`
 */

/**
 * Database (required).
 *
 * Use hostname only for DB_HOST; optional port via DB_PORT or legacy "host:3306"
 * (parsed in getDbConnection()).
 *
 * DB_NAME / SEISMO_ENTRIES_DB name the shared entries database (`seismo`).
 * Path satellites connect to `seismo_<slug>` for scores automatically.
 */
define('DB_HOST', 'localhost');
define('DB_NAME', 'seismo');
define('DB_USER', 'CHANGE_ME');
define('DB_PASS', 'CHANGE_ME');
define('SEISMO_ENTRIES_DB', 'seismo');
// define('DB_PORT', '3306'); // optional — omit to use the driver default (3306)

/**
 * Optional — override remote refresh secret (normally stored in mothership system_config
 * via Settings → Satellites; auto-created when you add a desk).
 */
// define('SEISMO_REMOTE_REFRESH_KEY', 'only-if-you-need-a-file-override');

/**
 * Optional — absolute mothership base URL (no trailing slash) for satellite Refresh.
 * Defaults to the current request host + {@see getBasePath()} when unset.
 */
// define('SEISMO_MOTHERSHIP_URL', 'https://seismo.live');
// Required for cron/CLI HTTP (e.g. Blick RSS); web preview can auto-detect the current host when unset.

/**
 * Optional per-desk branding override (normally taken from satellites_registry).
 */
// define('SEISMO_BRAND_TITLE', 'Seismo Security');
// define('SEISMO_BRAND_ACCENT', '#4a90e2');

/**
 * Optional — IANA timezone for dashboard day labels (data stays UTC in the database).
 */
// define('SEISMO_VIEW_TIMEZONE', 'Europe/Zurich');

/**
 * Optional — require login for the web UI.
 */
