{
    "name": "hektopascal/seismo",
    "description": "Seismo 0.8 — legislation / feed monitor",
    "require": {
        "php": ">=8.1",
        "easyrdf/easyrdf": "^1.1",
        "fivefilters/readability.php": "^3.1",
        "google/apiclient": "^2.15",
        "league/html-to-markdown": "^5.1",
        "masterminds/html5": "^2.9",
        "simplepie/simplepie": "^1.9",
        "symfony/css-selector": "^7.0",
        "symfony/dom-crawler": "^7.0",
        "symfony/html-sanitizer": "^7.0",
        "zbateson/mail-mime-parser": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "config": {
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "Seismo\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Seismo\\Tests\\": "tests/"
        }
    }
}
